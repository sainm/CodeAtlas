<struts-config>
  <controller processorClass="com.acme.legacy.web.AdminRequestProcessor"
              inputForward="true"
              maxFileSize="5M"/>
  <message-resources key="admin" parameter="com.acme.legacy.AdminResources"/>
  <global-forwards>
    <forward name="dashboard" path="/user/list.do"/>
  </global-forwards>
  <global-exceptions>
    <exception key="error.admin" type="com.acme.legacy.AdminException" path="/admin/error.jsp"/>
  </global-exceptions>
  <form-beans>
    <form-bean name="adminSearchForm" type="org.apache.struts.action.DynaActionForm">
      <form-property name="keyword" type="java.lang.String"/>
      <form-property name="page" type="java.lang.Integer" initial="1"/>
      <form-property name="includeDisabled" type="java.lang.Boolean" initial="false"/>
    </form-bean>
  </form-beans>
  <action-mappings>
    <action path="/user/list" type="com.acme.legacy.web.AdminUserAction" name="adminSearchForm" scope="request" input="/admin/user/list.jsp" parameter="method" validate="true">
      <forward name="success" path="admin.user.list"/>
      <exception key="error.admin.search" type="com.acme.legacy.AdminSearchException" path="/admin/user/list.jsp"/>
    </action>
  </action-mappings>
  <plug-in className="org.apache.struts.tiles.TilesPlugin">
    <set-property property="definitions-config" value="/WEB-INF/tiles-defs.xml"/>
    <set-property property="moduleAware" value="true"/>
  </plug-in>
</struts-config>
