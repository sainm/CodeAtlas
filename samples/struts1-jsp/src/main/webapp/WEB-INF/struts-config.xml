<struts-config>
  <controller processorClass="com.acme.legacy.web.LegacyRequestProcessor" inputForward="true" maxFileSize="20M"/>
  <form-beans>
    <form-bean name="userForm" type="com.acme.legacy.web.UserForm"/>
  </form-beans>
  <action-mappings>
    <action path="/user/save" type="com.acme.legacy.web.UserAction" name="userForm" scope="request" input="/user/edit.jsp">
      <forward name="success" path="/user/detail.jsp"/>
    </action>
  </action-mappings>
  <plug-in className="org.apache.struts.tiles.TilesPlugin">
    <set-property property="definitions-config" value="/WEB-INF/tiles-defs.xml"/>
  </plug-in>
  <plug-in className="org.apache.struts.validator.ValidatorPlugIn">
    <set-property property="pathnames" value="/WEB-INF/validator-rules.xml,/WEB-INF/validation.xml"/>
  </plug-in>
</struts-config>
